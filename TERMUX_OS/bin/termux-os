#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail

LOG="$HOME/TERMUX_OS/logs/os.log"
mkdir -p "$(dirname "$LOG")"

msg(){ echo "[$(date '+%F %T')] $*" | tee -a "$LOG"; }

lean(){
 pkill -9 -f node 2>/dev/null || true
 pkill -9 -f npm 2>/dev/null || true
 pkill -9 -f cloudflared 2>/dev/null || true
 rm -rf ~/.npm/_cacache 2>/dev/null || true
 msg "LEAN_MODE"
 free -h
}

build(){
 msg "BUILD_MODE"
 if [ -f package.json ]; then
   npm install
   npm run build || npm run dev
 else
   msg "NO_PACKAGE_JSON"
 fi
}

deploy(){
 msg "DEPLOY_MODE"
 if [ -f package.json ]; then
   pkill -9 -f "next start" 2>/dev/null || true
   nohup npm run start -- --hostname 0.0.0.0 --port 3000 >/dev/null 2>&1 &
   sleep 6
   cloudflared tunnel --protocol http2 --url http://127.0.0.1:3000
 else
   msg "NO_APP_FOUND"
 fi
}

reset(){
 pkill -9 -f node 2>/dev/null || true
 pkill -9 -f npm 2>/dev/null || true
 pkill -9 -f cloudflared 2>/dev/null || true
 find ~ -type f \( -name "*.log" -o -name "*.pid" \) -delete 2>/dev/null || true
 rm -rf .next node_modules/.cache ~/.npm/_cacache 2>/dev/null || true
 sync
 msg "RESET_DONE"
 free -h
}

auto(){
 AVAIL=$(free -m | awk '/Mem:/ {print $7}')
 if [ "$AVAIL" -lt 700 ]; then
   reset
 else
   lean
 fi
}

status(){
 echo "=== STATUS ==="
 free -h
 echo
 df -h ~
 echo
 ps -ef | grep -E "node|npm|cloudflared" | grep -v grep || true
}

case "${1:-}" in
 lean) lean ;;
 build) build ;;
 deploy) deploy ;;
 reset) reset ;;
 auto) auto ;;
 status) status ;;
 *) echo "use: termux-os {lean|build|deploy|reset|auto|status}" ;;
esac
